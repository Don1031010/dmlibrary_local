# Temporary HTTP-only config used before SSL cert is issued.
# After getting the cert, replace this with dmlibrary.conf (remove .http-only extension).

server {
    listen 80;
    server_name private.marianstreet.tokyo;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 200 'OK';
        add_header Content-Type text/plain;
    }
}
